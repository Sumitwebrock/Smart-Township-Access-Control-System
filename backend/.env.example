# ─────────────────────────────────────────────────────────────────────────────
# Smart Township Access Control System – environment configuration
# Copy this file to .env and fill in your real values.
# ─────────────────────────────────────────────────────────────────────────────

# Application
APP_NAME="Smart Township Access Control System"
APP_VERSION="1.0.0"
DEBUG=false

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://postgres:password@localhost:5432/township_gate

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-secure-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 hours

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads/photos
MAX_UPLOAD_SIZE_MB=5

# ── CORS ──────────────────────────────────────────────────────────────────────
# Separate multiple origins with commas (as a JSON array string)
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
